# ============================================
# Configuración del Frontend - ERP/POS YOMYOM
# ============================================
#
# INSTRUCCIONES:
# 1. Copiar este archivo a .env
# 2. Modificar REACT_APP_API_URL según tu entorno
# 3. NUNCA commitear el archivo .env al repositorio
#
# cp .env.example .env
#

# URL del backend API
# En desarrollo local: http://localhost:8000
# En producción: https://api.tudominio.com
REACT_APP_API_URL=http://localhost:8000

# ============================================
# Notas
# ============================================
#
# - Las variables de entorno en React deben comenzar con REACT_APP_
# - Después de cambiar .env, reiniciar el servidor de desarrollo (npm start)
# - En producción, estas variables se inyectan en tiempo de build
#
